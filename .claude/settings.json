{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-gate.sh\"",
            "statusMessage": "reconGG: git review/graphify gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-post-pull.sh\"",
            "statusMessage": "reconGG: post-pull graphify reminder"
          }
        ]
      }
    ]
  }
}
